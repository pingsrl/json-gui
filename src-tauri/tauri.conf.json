{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JsonGUI",
  "version": "0.5.11",
  "identifier": "com.pingsrl.jsongui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "JsonGUI",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "ext": ["json"],
        "name": "JSON File",
        "description": "JSON data file",
        "mimeType": "application/json",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pingsrl/json-gui/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFMTE4NUQ0M0Y1REI4OUIKUldTYnVGMC8xSVVSVHFIK2V1ZzZzcTV2NEhOZmtNelJrZ3l2SS9zM09KK3lqdlBraVZNeXViSGQK"
    }
  }
}
